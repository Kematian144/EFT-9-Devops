        "header": [],
        "url": "{{baseUrl}}/user/{{userId}}"
      }
    },
    {
      "name": "Agregar usuario - POST",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Camila\",\n  \"lastName\": \"Rojas\",\n  \"email\": \"camila.rojas.eft@gmail.com\"\n}"
        },
        "url": "{{baseUrl}}/user"
      }
    },
    {
      "name": "Editar usuario - PUT",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Camila\",\n  \"lastName\": \"Rojas Soto\",\n  \"email\": \"camila.rojas.actualizada@gmail.com\"\n}"
        },
        "url": "{{baseUrl}}/user/{{userId}}"
